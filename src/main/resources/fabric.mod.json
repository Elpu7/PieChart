{
  "schemaVersion": 1,
  "id": "piechart",
  "version": "${version}",

  "name": "PieChart",
  "description": "Mod that allows you to toggle and edit pie chart.",
  "authors": ["Elpu7"],
  "contact": {
    "homepage": "https://modrinth.com/project/piechart",
    "issues": "https://github.com/Elpu7/PieChart/issues",
    "sources": "https://github.com/Elpu7/PieChart"
  },

  "license": "MIT",
  "icon": "assets/piechart/icon.png",

  "environment": "client",
  "entrypoints": {
    "client": ["dev.elpu7.piechart.client.PiechartClient"],
    "main": ["dev.elpu7.piechart.Piechart"]
  },

  "mixins": [
    "piechart.mixins.json"
    ,{
      "config": "piechart.client.mixins.json",
      "environment": "client"
    }
  ],

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
